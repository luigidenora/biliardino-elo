# VAPID Keys per Web Push Notifications
# Generate con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BOUHmi8SrZME9HKSAyqwKpTSiW1BATEoejeFqSzCUkxa718VNmx6ATtiUbi4YmCl-eAQC6kndhXCP-vZl9QHfpE
VAPID_PRIVATE_KEY=DSsRUWl2aJBnREGwPNj9erD4vwC3xRNFCVlhYqb4zq0

# Vercel Blob Storage (auto-generated da Vercel Dashboard)
# Usato per salvare le push subscriptions
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# Vercel KV (Redis) (auto-generated da Vercel Dashboard)
# Usato per le conferme temporanee con auto-expire
KV_REST_API_URL=your_kv_url_here
KV_REST_API_TOKEN=your_kv_token_here
KV_REST_API_READ_ONLY_TOKEN=your_kv_readonly_token_here

# Modalità Sviluppo (dev mode)
# Abilita mock data, dev toolbar, bypass autenticazione
# IMPORTANTE: Imposta SEMPRE a false in produzione!
# In .env.development: true
# In .env.production: false
VITE_DEV_MODE=false

# DB Provider
# Seleziona l'implementazione del database da usare a compile-time.
# Rollup elimina dal bundle le implementazioni non usate.
#   firebase  → Firestore (default produzione)
#   supabase  → PostgreSQL via Supabase
#   mock      → dati in memoria (equivale a VITE_DEV_MODE=true)
VITE_DB=firebase

# Supabase (usato solo se VITE_DB=supabase)
# Ottenibili da: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API Base URL (opzionale)
# Default: /api (stesso dominio)
# Per chiamate cross-origin da GitHub Pages: https://your-api-domain.vercel.app/api
VITE_API_BASE_URL=/api

# Admin API Token (opzionale – usato dalla dev toolbar per broadcast e clear)
# Generare usando: npm run generate-admin-token (vedi la sezione "Admin API Token" nella documentazione del progetto per i dettagli)
# In alternativa salvalo in localStorage come biliardino_admin_token
VITE_ADMIN_TOKEN=your_admin_token_here
